NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
TRUST_PROXY=false
MONGODB_URI=mongodb://localhost:27017/expense_tracker
JWT_ACCESS_SECRET=replace_with_a_random_32_plus_char_secret
JWT_REFRESH_SECRET=replace_with_a_random_32_plus_char_secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
COOKIE_SECURE=false
EMAIL_ENABLED=true
# In automated tests, email is disabled by default.
# Set to true only if you intentionally want tests to send real emails.
ALLOW_TEST_EMAILS=false

# Email verification (Gmail OAuth2 preferred)
# Option A: Gmail OAuth2 using EMAIL_* aliases accepted by the app
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_FROM=your_email@gmail.com
EMAIL_CLIENT_ID=your_google_client_id
EMAIL_CLIENT_SECRET=your_google_client_secret
EMAIL_REFRESH_TOKEN=your_google_refresh_token
EMAIL_ACCESS_TOKEN=
EMAIL_REDIRECT_URI=https://developers.google.com/oauthplayground

# Option B: Traditional SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@example.com
